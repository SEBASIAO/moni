{
  "name": "@moni/mobile",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "dev": "react-native start",
    "build:android": "cd android && ./gradlew assembleRelease",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests --ci",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "react-native clean",
    "pod-install": "cd ios && pod install"
  },
  "dependencies": {
    "@moni/api": "workspace:*",
    "@moni/types": "workspace:*",
    "@moni/ui": "workspace:*",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "@supabase/supabase-js": "^2.47.0",
    "@tanstack/react-query": "^5.62.0",
    "react": "^19.1.0",
    "react-native": "0.81.0",
    "react-native-paper": "^5.12.0",
    "react-native-safe-area-context": "^4.14.0",
    "react-native-screens": "^4.4.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-vector-icons": "^10.2.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@moni/config-eslint": "workspace:*",
    "@moni/config-typescript": "workspace:*",
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/runtime": "^7.25.0",
    "@react-native/babel-preset": "^0.81.0",
    "@react-native/metro-config": "^0.81.0",
    "@react-native/typescript-config": "^0.81.0",
    "@testing-library/jest-native": "^5.4.0",
    "@testing-library/react-native": "^12.9.0",
    "@types/react": "^19.1.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "typescript": "^5.7.0"
  },
  "jest": {
    "preset": "react-native",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json"],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@react-navigation|react-native-paper|react-native-vector-icons|react-native-safe-area-context|react-native-screens|@moni)/)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  }
}
