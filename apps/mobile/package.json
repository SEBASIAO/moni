{
  "name": "@moni/mobile",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "dev": "react-native start",
    "build:android": "cd android && ./gradlew assembleRelease",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests --ci",
    "test:watch": "jest --watch",
    "postinstall": "cd node_modules && for pkg in react-native @react-native @react-native-community @react-native-async-storage; do ln -sf ../../../node_modules/$pkg $pkg 2>/dev/null; done; true",
    "test:coverage": "jest --coverage",
    "clean": "react-native clean",
    "pod-install": "cd ios && pod install"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.8",
    "@moni/api": "workspace:*",
    "@moni/types": "workspace:*",
    "@moni/ui": "workspace:*",
    "@nozbe/watermelondb": "^0.28.0",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native-documents/picker": "^12.0.1",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "@shopify/flash-list": "^2.3.1",
    "@supabase/supabase-js": "^2.47.0",
    "@tanstack/react-query": "^5.62.0",
    "i18next": "^26.0.3",
    "lucide-react-native": "^1.7.0",
    "react": "^19.1.0",
    "react-i18next": "^17.0.2",
    "react-native": "0.81.0",
    "react-native-bootsplash": "^7.2.0",
    "react-native-currency-input": "^1.1.1",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "^2.31.0",
    "react-native-localize": "^3.7.0",
    "react-native-paper": "^5.12.0",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.4.0",
    "react-native-svg": "^15.15.4",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-vector-icons": "^10.2.0",
    "react-native-worklets": "0.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/runtime": "^7.25.0",
    "@moni/config-eslint": "workspace:*",
    "@moni/config-typescript": "workspace:*",
    "@react-native-community/cli": "^20.1.3",
    "@react-native-community/cli-platform-android": "^20.1.3",
    "@react-native-community/cli-platform-ios": "^20.1.3",
    "@react-native/babel-preset": "^0.81.0",
    "@react-native/metro-config": "^0.81.0",
    "@react-native/typescript-config": "^0.81.0",
    "@testing-library/jest-native": "^5.4.0",
    "@testing-library/react-native": "^12.9.0",
    "@types/react": "^19.1.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "cjs": "link:@nozbe/watermelondb/babel/cjs",
    "jest": "^29.7.0",
    "typescript": "^5.7.0"
  },
  "jest": {
    "preset": "react-native",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@react-navigation|react-native-paper|react-native-vector-icons|react-native-safe-area-context|react-native-screens|@moni)/)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  }
}
