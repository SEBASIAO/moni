# Supabase — local dev defaults (from supabase start)
SUPABASE_URL=http://10.0.2.2:54321
SUPABASE_ANON_KEY=your-local-anon-key

# Note: use 10.0.2.2 for Android emulator (maps to host machine's localhost)
# For iOS simulator, use 127.0.0.1 or localhost

# ── Firebase App Distribution ────────────────────────────────────
# These are NOT used at runtime — they are used by CI only.
# Store the real values as GitHub Secrets, not here.
# See FIREBASE.md for full setup instructions.
#
# FIREBASE_APP_ID_ANDROID=1:123456789:android:abcdef0123456789
# FIREBASE_APP_ID_IOS=1:123456789:ios:abcdef0123456789
