# Required for pnpm + React Native monorepo
# Metro bundler requires hoisted node_modules (it doesn't understand symlinks)
node-linker=hoisted

# Needed for React Native peer dependency resolution
shamefully-hoist=true

# Don't fail on peer dep mismatches (RN ecosystem has many)
strict-peer-dependencies=false

# Hoist React Native and related packages to root node_modules
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=*react*
public-hoist-pattern[]=@react-native*
public-hoist-pattern[]=*jest*
public-hoist-pattern[]=*babel*
public-hoist-pattern[]=*metro*
